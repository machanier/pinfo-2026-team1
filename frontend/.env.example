# PINFO-190 — Auth0 SPA configuration.
#
# Copy this file to .env (local dev) or set the variables in the
# Vite build environment (CI / Docker build) before `npm run build`.
# Vite only exposes variables prefixed with VITE_ to the bundle.
#
# Where each value comes from in the Auth0 dashboard:
#   VITE_AUTH0_DOMAIN     — Applications > <your SPA app> > Settings > Domain
#                           (e.g. unigevents.eu.auth0.com)
#   VITE_AUTH0_CLIENT_ID  — same screen, "Client ID"
#   VITE_AUTH0_AUDIENCE   — APIs > <your API> > Settings > Identifier
#                           (e.g. https://api.unigevents.com — must
#                           match mp.jwt.verify.audiences in the
#                           backend services)
#
# All three values are PUBLIC — they ship in the SPA bundle and are
# expected to be visible to anyone using the app. None of them is a
# secret. Do not commit a real .env that points to a tenant we don't
# want users to reach.

VITE_AUTH0_DOMAIN=unigevents.eu.auth0.com
VITE_AUTH0_CLIENT_ID=replace-with-spa-client-id
VITE_AUTH0_AUDIENCE=https://api.unigevents.com
