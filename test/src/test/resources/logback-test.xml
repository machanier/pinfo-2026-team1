<configuration>
    <!-- Suppress DEBUG-level Karate logs that expose WebDriver HTTP traffic
         (including plain-text passwords sent via input()). INFO is enough
         to see step results, errors and warnings. -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread]  %-5level %logger - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Karate internals: INFO hides WebDriver HTTP request/response bodies -->
    <logger name="com.intuit.karate" level="INFO"/>

    <!-- Apache HTTP client used by Karate WebDriver — DEBUG logs raw HTTP including {"text":"<password>"} -->
    <logger name="org.apache.http" level="WARN"/>

    <root level="WARN">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>

