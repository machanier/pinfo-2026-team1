# Keep the Docker build context small and free of secrets.
# The build (frontend/Dockerfile) runs `npm ci` + `vite build`, so deps and
# build output are regenerated inside the image and must not be copied in.

# Dependencies & build output (regenerated by npm ci / vite build)
node_modules
dist

# Local env / secrets — Vite inlines any VITE_* at build time, so a dev's
# local .env must NEVER enter the build context. Prod values come from
# --build-arg in CI (see Dockerfile), not from a file.
.env
.env.*
!.env.example

# VCS, editor & OS cruft (not needed to build)
.git
.gitignore
.DS_Store
.vscode

# Logs, caches & test output
npm-debug.log*
yarn-error.log*
*.log
coverage
.vite
