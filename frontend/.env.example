# PINFO-190 — Auth0 SPA configuration.
#
# Copy this file to .env (local dev) or set the variables in the
# Vite build environment (CI / Docker build) before `npm run build`.
# Vite only exposes variables prefixed with VITE_ to the bundle.
#
# Where each value comes from in the Auth0 dashboard:
#   VITE_AUTH0_DOMAIN     — Applications > <your SPA app> > Settings > Domain
#                           (e.g. dev-cy8uphtpfx5bdclo.us.auth0.com)
#   VITE_AUTH0_CLIENT_ID  — same screen, "Client ID"
#   VITE_AUTH0_AUDIENCE   — APIs > <your API> > Settings > Identifier
#                           https://api.unigevents.ch — must match
#                           mp.jwt.verify.audiences in every backend
#                           service that validates JWTs.
#
# All three values are PUBLIC — they ship in the SPA bundle and are
# expected to be visible to anyone using the app. None of them is a
# secret. Do not commit a real .env that points to a tenant we don't
# want users to reach.

VITE_AUTH0_DOMAIN=your-tenant.region.auth0.com
VITE_AUTH0_CLIENT_ID=your-auth0-client-id
VITE_AUTH0_AUDIENCE=https://api.unigevents.ch

VITE_API_URL=http://localhost:8081
VITE_API_TIMEOUT=30000

# Cloudinary configuration now lives SERVER-SIDE (user-service, via Doppler).
# Avatar uploads are signed by the backend: the cloud name + API key are
# returned per request from /api/users/me/avatar-upload-signature and the API
# secret never ships in this bundle, so no VITE_CLOUDINARY_* variables are
# needed here anymore.
