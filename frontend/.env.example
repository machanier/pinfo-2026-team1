# ============================================================================
# Auth0 Configuration
# ============================================================================
# Obtenez ces valeurs depuis votre dashboard Auth0 (https://manage.auth0.com)

# Domain Auth0 (e.g., your-domain.auth0.com)
VITE_AUTH0_DOMAIN=YOUR_AUTH0_DOMAIN

# Client ID Auth0
VITE_AUTH0_CLIENT_ID=YOUR_AUTH0_CLIENT_ID

# API Identifier / Audience (configured in Auth0 API settings)
# Ceci assure que Auth0 émet des tokens appropriés pour votre API
VITE_AUTH0_AUDIENCE=YOUR_API_IDENTIFIER

# ============================================================================
# Backend Configuration
# ============================================================================

# URL de base de votre backend API
VITE_API_URL=http://localhost:8081

# Timeout pour les requêtes API (en ms)
VITE_API_TIMEOUT=30000
