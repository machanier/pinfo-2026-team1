# ============================================================
# UNIGEvents — Environment Variables Template (Microservices)
# ============================================================
# Copy this file to .env and fill in your values:
#   cp docker/.env.example docker/.env
#
# The .env file is ignored by git (never commit it).
# ============================================================

# User Service database
USER_DB_NAME=users_db
USER_DB_USER=user_service
USER_DB_PASSWORD=user_service_pwd
USER_DB_PORT=5433

# Event Service database
EVENT_DB_NAME=events_db
EVENT_DB_USER=event_service
EVENT_DB_PASSWORD=event_service_pwd
EVENT_DB_PORT=5434

# Registration Service database
REGISTRATION_DB_NAME=registrations_db
REGISTRATION_DB_USER=registration_service
REGISTRATION_DB_PASSWORD=registration_service_pwd
REGISTRATION_DB_PORT=5435

# Notification Service database
NOTIFICATION_DB_NAME=notifications_db
NOTIFICATION_DB_USER=notification_service
NOTIFICATION_DB_PASSWORD=notification_service_pwd
NOTIFICATION_DB_PORT=5436

# Search Service database
SEARCH_DB_NAME=search_db
SEARCH_DB_USER=search_service
SEARCH_DB_PASSWORD=search_service_pwd
SEARCH_DB_PORT=5437

# Moderation Service database
MODERATION_DB_NAME=moderation_db
MODERATION_DB_USER=moderation_service
MODERATION_DB_PASSWORD=moderation_service_pwd
MODERATION_DB_PORT=5438

# React frontend
FRONTEND_PORT=3000

